# Replace <FQDN> with the Azure VM's public DNS name before deploying.
# Caddy auto-provisions a Let's Encrypt certificate and renews it.

<FQDN> {
    encode zstd gzip

    # Forward to the local Node service
    reverse_proxy localhost:8080 {
        # Large downloads can take a while; bump timeouts accordingly
        transport http {
            read_timeout 300s
            write_timeout 300s
        }
    }

    log {
        output file /var/log/caddy/imageright-proxy.log
        format json
    }
}
