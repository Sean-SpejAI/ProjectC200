# Upstream ImageRight SOAP/ASMX endpoint. Inside the customer VPN — plain HTTP
# on port 80. The Host header value (set separately below) is the FQDN the
# server expects in the request even though we target the IP directly.
IMAGERIGHT_SOAP_URL=http://192.168.11.179/imageright.webservice/IRWebService40.asmx
IMAGERIGHT_SOAP_HOST=irtest-appsvr.nodakmutual.com

# 32+ char random token. Supabase Edge Functions send this as Bearer.
PROXY_SHARED_SECRET=replace-with-output-of-openssl-rand-hex-32

# ImageRight service account (spejai). Every proxy request opens a new SOAP
# session — UserLogin with connName=Test — and uses the returned token for
# that request's sequence of operations.
IR_USERNAME=spejai
IR_PASSWORD=replace-with-actual-password

PORT=8080
